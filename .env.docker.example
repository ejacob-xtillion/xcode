# Docker Environment Configuration for xCode

# Agent URL (internal Docker network)
LA_FACTORIA_URL=http://xcode-agent:8000

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# OpenAI Configuration (required for agent execution)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: LLM Configuration
# MODEL=gpt-4
# TEMPERATURE=0.7

# Optional: Verbose Output
# VERBOSE=true
