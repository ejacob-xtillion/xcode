# xCode — single configuration file at the repository root (copy to `.env`).
# Docker Compose loads this file for CLI and agent services. The agent also reads
# `<repo>/.env` via Pydantic. Optional override: XCODE_ENV_FILE=/path/to/.env

# -----------------------------------------------------------------------------
# Neo4j (host / local tooling — Compose overrides URI for containers)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# OpenAI API (agent + compose interpolation). Set one of OPENAI_API_KEY or LLM_API_KEY.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
LLM_API_KEY=
# Optional alias for LLM_BASE_URL (Compose passes it through as LLM_BASE_URL for the agent)
# OPENAI_BASE_URL=https://your-litellm-host.example.com
# openai | openai_proxy | bedrock | azure | google_genai | custom
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

# OpenAI-compatible gateway (optional — docker compose --profile llm-proxy up -d; default image is LiteLLM, swappable)
# LLM_PROVIDER=openai_proxy, LLM_BASE_URL=http://llm-proxy:4000/v1, LLM_API_KEY=<same as LLM_PROXY_AUTH_KEY>
# LLM_PROXY_AUTH_KEY=
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=600
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=600

# -----------------------------------------------------------------------------
# CLI knowledge graph (xgraph) — omit XCODE_LLM_ENDPOINT for OpenAI cloud defaults
# -----------------------------------------------------------------------------
XCODE_MODEL=gpt-4.1-mini
# XCODE_LLM_ENDPOINT=http://localhost:11434

# -----------------------------------------------------------------------------
# Agent API (optional in Docker; compose sets DB overrides when using postgres service)
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
API_VERSION=1.0.0
API_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://xagents_user:xagents_password@postgres:5432/xagents_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xagents_user
POSTGRES_PASSWORD=xagents_password
POSTGRES_DB=xagents_db

# -----------------------------------------------------------------------------
# Docker CLI → agent (set automatically in compose; useful for local CLI hitting agent)
# -----------------------------------------------------------------------------
# LA_FACTORIA_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# LangSmith (optional)
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# -----------------------------------------------------------------------------
# OpenTelemetry (optional)
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=xcode-agent-api
OTEL_EXPORT_CONSOLE=false

# -----------------------------------------------------------------------------
# JWT (optional)
# -----------------------------------------------------------------------------
JWT_ENABLED=false

# -----------------------------------------------------------------------------
# Shell tool + tool retry (optional — see agent docs for full list)
# -----------------------------------------------------------------------------
# SHELL_TOOL_ENABLED=true
# SHELL_COMMAND_TIMEOUT_SECONDS=120
# TOOL_RETRY_ENABLED=true
# TOOL_RETRY_MAX_ATTEMPTS=2
