# Core Application Settings
ENVIRONMENT=dev
API_VERSION=1.0.0
API_PORT=8000
LOG_LEVEL=INFO

# CORS Configuration
# CORS_ALLOWED_ORIGINS=[] ("https://yourdomain.com","https://www.yourdomain.com","https://app.yourdomain.com")

# LLM Configuration
LLM_API_KEY=sk-placeholder
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://litellm.xtillion.com/
# Ollama (OpenAI-compatible): use /v1 suffix, e.g. http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1
LLM_TEMPERATURE=0.0

# Langsmith configuration
# visit link for setup: https://docs.smith.langchain.com/observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Database Configuration
DATABASE_URL=postgresql://xagents_user:xagents_password@postgres:5432/xagents_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xagents_user
POSTGRES_PASSWORD=xagents_password
POSTGRES_DB=xagents_db

# OpenTelemetry Configuration
OTEL_ENABLED=true
OTEL_SERVICE_NAME=x-agents-api
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4317  # Uncomment when you want to export traces (AWS X-Ray, Azure App Insights, GCP Cloud Trace)
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:9090  # Uncomment when want to export HTTP metrics (AWS CloudWatch, Azure Monitor, GCP Cloud Monitoring)
# OTEL_EXPORT_CONSOLE=true  # Uncomment to export metrics to console for local debugging
# OTEL_EXPORT_INTERVAL_MILLIS=60000  # Uncomment to change metric export interval (default: 60000ms)
# JWT Authentication Configuration
# Set JWT_ENABLED=true to enable JWT authentication
JWT_ENABLED=false
# JWT_ISSUER=https://your-auth-provider.com/  # Required when JWT_ENABLED=true
# JWT_AUDIENCE=your-api-identifier  # Required when JWT_ENABLED=true
# JWT_ALGORITHMS=["RS256"]  # Optional, defaults to RS256

# Shell tool (run_shell_command) — runs subprocesses inside the agent container
# SHELL_TOOL_ENABLED=true
# SHELL_ALLOWED_ROOTS_CSV=/Users/you,/other/allowed  # optional; default = filesystem MCP root
# SHELL_COMMAND_TIMEOUT_SECONDS=120
# SHELL_MAX_OUTPUT_BYTES=65536
# SHELL_AUTO_INSTALL_REQUIREMENTS=true   # Auto-install deps before pytest-like commands:
#   - requirements.txt: uv pip / pip install -r
#   - pyproject.toml (no requirements.txt) + uv on PATH: uv sync, then run via uv run
# SHELL_SKIP_REDUNDANT_REQUIREMENTS_INSTALL=true  # in-process dedupe after first successful install/sync
# SHELL_PIP_INSTALL_TIMEOUT_SECONDS=300  # timeout for requirements.txt install or uv sync
